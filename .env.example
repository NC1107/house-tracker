# --- Database ---
# For the bundled docker-compose Postgres, leave DATABASE_URL unset (compose supplies a
# default pointing at the internal `db` service). Set it only to use an external DB.
# DATABASE_URL=postgres://user:pass@host:5432/db?sslmode=require

# Credentials for the bundled Postgres (docker-compose `db` service):
POSTGRES_USER=housetracker
POSTGRES_PASSWORD=housetracker
POSTGRES_DB=housetracker

# Host port the web app is published on (container always listens on 3000):
WEB_PORT=3000

# --- Data source API keys (all free to obtain) ---
FRED_API_KEY=            # https://fred.stlouisfed.org/docs/api/api_key.html
CENSUS_API_KEY=          # https://api.census.gov/data/key_signup.html
HUD_TOKEN=               # https://www.huduser.gov/portal/dataset/fmr-api.html

# --- Notifications (Phase 1d) ---
RESEND_API_KEY=          # https://resend.com
VAPID_PUBLIC_KEY=        # generate with: npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=

# --- Auth (Phase 1d) ---
AUTH_SECRET=             # openssl rand -base64 32
